rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Secure chats: only allow read/write/create if user is a participant
    match /chats/{conversationId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      
      // Secure messages inside a chat
      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(conversationId)).data.participants;
      }
    }
    
    // User profile document rules
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Food listings rules
    match /food_posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Transaction and requests rules
    match /food_requests/{requestId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Reviews rules
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.reviewerId;
    }

    // Orders rules
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    
    // Payments rules
    match /payments/{paymentId} {
      allow read, write: if request.auth != null;
    }
    
    // Refunds rules
    match /refunds/{refundId} {
      allow read, write: if request.auth != null;
    }
  }
}
